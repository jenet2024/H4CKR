# ── Application ──────────────────────────────────────
APP_NAME=H4CKR
APP_VERSION=1.0.0
DEBUG=True

# ── Base de données ───────────────────────────────────
# DATABASE_URL=sqlite:///./h4ckr.db
# DATABASE_URL: str = "mysql+pymysql://root:@localhost:3306/h4ckr_game"

DATABASE_URL="mysql+pymysql://root:@localhost:3306/h4ckr_game"


# ── JWT ───────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY_256_BITS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OAuth Google (placeholder) ────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── OAuth Twitter/X (placeholder) ────────────────────
TWITTER_CLIENT_ID=YOUR_TWITTER_CLIENT_ID
TWITTER_CLIENT_SECRET=YOUR_TWITTER_CLIENT_SECRET
TWITTER_REDIRECT_URI=http://localhost:8000/auth/twitter/callback

# ── Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Assets ────────────────────────────────────────────
ASSETS_DIR=./assets
